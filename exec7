Questão 7 - resposta


#include <stdio.h>

int main() {

    int numero;
    int soma = 0;

    
    while(soma <= 100) {

        printf("Digite um numero: ");
        scanf("%d", &numero);

        
        soma = soma + numero;

    }

   
    printf("A soma ultrapassou 100.\n");
    printf("Soma final = %d", soma);

    return 0;
}
