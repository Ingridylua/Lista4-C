Questão 10 - resposta

#include <stdio.h>

int main() {

    int i;
    int numero;
    int positivo = 0;
    int negativo = 0;
    int zero = 0;

    
    for(i = 1; i <= 10; i++) {

        printf("Digite o %d numero: ", i);
        scanf("%d", &numero);

        
        if(numero >0) {

            positivo++;

        } else if(numero < 0) {

            negativo++;

        }
        
        
        else {

            zero++;

        }

   
    printf("\nRESULTADOS\n");

    printf("Positivos: %d", positivo);
    printf("Negativos: %d", negativo);
    printf("Zeros: %d", zero);

    return 0;
}
