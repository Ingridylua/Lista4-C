Questão 10 - resposta

#include <stdio.h>

int main() {

    int i;
    int numero;
    int maior;
    int menor;

    
    printf("Digite o numero 1: ");
    scanf("%d", &numero);

   
    maior = numero;
    menor = numero;

    
    for(i = 2; i <= 5; i++) {

        printf("Digite o numero %d: ", i);
        scanf("%d", &numero);

        if(numero > maior) {

            maior = numero;
        
        if(numero < menor) {

            menor = numero;

        }

    }

    
    printf("\nMaior numero: %d", maior);
    printf("Menor numero: %dn", menor);

    return 0;
}
